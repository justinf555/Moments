using Gtk 4.0;
using Adw 1;

template $MomentsEditFilterSwatch : Gtk.Widget {
  layout-manager: Gtk.BinLayout {};

  Gtk.ToggleButton toggle {
    styles ["flat", "filter-button"]

    child: Gtk.Box {
      orientation: vertical;
      halign: center;
      valign: center;

      Gtk.Box colour_box {
        width-request: 80;
        height-request: 80;
        styles ["filter-swatch"]
      }

      Gtk.Label name_label {
        styles ["caption"]
      }
    };
  }
}
