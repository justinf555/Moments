{
    "id": "io.github.justinf555.Moments.Devel",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command": "moments",
    "finish-args": [
        "--share=network",
        "--device=dri",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--talk-name=org.freedesktop.secrets",
        "--filesystem=home:ro"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "build-args": [
            "--share=network"
        ],
        "env": {
            "SQLX_OFFLINE": "true",
            "RUST_BACKTRACE": "1"
        }
    },
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "moments",
            "builddir": true,
            "buildsystem": "meson",
            "config-opts": [
                "--libdir=lib",
                "-Dprofile=development"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": ".."
                }
            ]
        }
    ]
}
