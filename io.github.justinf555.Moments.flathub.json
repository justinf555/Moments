{
    "id" : "io.github.justinf555.Moments",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "sdk-extensions" : [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command" : "moments",
    "finish-args" : [
        "--share=network",
        "--share=ipc",
        "--device=dri",
        "--socket=wayland",
        "--socket=fallback-x11",
        "--socket=pipewire"
    ],
    "build-options" : {
        "append-path" : "/usr/lib/sdk/rust-stable/bin"
    },
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules" : [
        {
            "name" : "moments",
            "builddir" : true,
            "buildsystem" : "meson",
            "config-opts" : [
                "-Dbuildtype=release"
            ],
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://github.com/justinf555/Moments.git",
                    "tag" : "v0.3.0",
                    "commit" : "08b7764500032ca0623e6cfce1a82417933bb6a6"
                },
                "cargo-sources.json",
                {
                    "type" : "shell",
                    "commands" : [
                        "mkdir -p .cargo",
                        "cat cargo/config >> .cargo/config.toml"
                    ]
                }
            ]
        }
    ]
}
