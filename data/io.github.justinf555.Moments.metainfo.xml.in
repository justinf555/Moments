<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@APP_ID@</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Moments</name>
  <summary>Manage your photo library</summary>
  <description>
    <p>Moments is a photo management application for the GNOME desktop. Browse, organize, and manage your photo library with a clean, modern interface.</p>
    <p>Connect to a local folder or an Immich server to manage your photos. The Immich backend works fully offline, caching everything locally and syncing when connected.</p>
    <p>Moments supports JPEG, PNG, WebP, HEIC, TIFF, and common RAW formats, as well as video playback.</p>
  </description>

  <developer id="io.github.justinf555">
    <name>Justin F</name>
  </developer>

  <url type="homepage">https://github.com/justinf555/Moments</url>
  <url type="vcs-browser">https://github.com/justinf555/Moments</url>
  <url type="bugtracker">https://github.com/justinf555/Moments/issues</url>
  <url type="contribute">https://github.com/justinf555/Moments/blob/main/CONTRIBUTING.md</url>

  <translation type="gettext">moments</translation>
  <launchable type="desktop-id">@APP_ID@.desktop</launchable>

  <keywords>
    <keyword>photo</keyword>
    <keyword>gallery</keyword>
    <keyword>library</keyword>
    <keyword>immich</keyword>
    <keyword>organize</keyword>
    <keyword>pictures</keyword>
    <keyword>album</keyword>
  </keywords>

  <!-- No restricted content — app manages user's own photos. -->
  <content_rating type="oars-1.1">
    <content_attribute id="social-info">none</content_attribute>
  </content_rating>

  <branding>
    <color type="primary" scheme_preference="light">#99c1f1</color>
    <color type="primary" scheme_preference="dark">#1a5fb4</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>https://github.com/justinf555/Moments/raw/main/data/screenshots/moments_1.png</image>
      <caption>Browsing photos in the library</caption>
    </screenshot>
    <screenshot>
      <image>https://github.com/justinf555/Moments/raw/main/data/screenshots/moments_2.png</image>
      <caption>Library preferences and statistics</caption>
    </screenshot>
    <screenshot>
      <image>https://github.com/justinf555/Moments/raw/main/data/screenshots/moments_3.png</image>
      <caption>Photo viewer with EXIF metadata panel</caption>
    </screenshot>
    <screenshot>
      <image>https://github.com/justinf555/Moments/raw/main/data/screenshots/moments_4.png</image>
      <caption>Full-screen photo viewer</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="0.3.0" date="2026-04-13">
      <description translate="no">
        <p>Referenced storage mode and Flatpak sandbox improvements.</p>
        <ul>
          <li>New storage option — photos stay in your folders, Moments indexes them in place</li>
          <li>Improved Flatpak sandbox compliance — no longer requires blanket filesystem access</li>
          <li>Faster album and thumbnail loading</li>
          <li>Bug fixes for selection, video playback, and trash view</li>
        </ul>
      </description>
    </release>
    <release version="0.2.0" date="2026-04-05">
      <description translate="no">
        <p>Selection mode, GNOME 50, and quality improvements.</p>
        <ul>
          <li>Selection mode with checkbox overlays and batch actions</li>
          <li>Album picker with search and cover thumbnails</li>
          <li>Redesigned photo and video viewer</li>
          <li>Updated to GNOME 50 runtime</li>
          <li>Accessibility improvements</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-03-27">
      <description translate="no">
        <p>Initial release.</p>
        <ul>
          <li>Local and Immich server library backends</li>
          <li>Photo grid with adjustable zoom levels</li>
          <li>RAW and video format support</li>
          <li>Albums and people management</li>
          <li>EXIF metadata viewer</li>
          <li>Favourites and trash</li>
        </ul>
      </description>
    </release>
  </releases>

</component>
